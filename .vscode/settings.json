{
  "C_Cpp_Runner.cCompilerPath": "cl.exe",
  "C_Cpp_Runner.cppCompilerPath": "cl.exe",
  "C_Cpp_Runner.debuggerPath": "devenv.exe",
  "C_Cpp_Runner.cStandard": "c17",
  "C_Cpp_Runner.cppStandard": "cpp20",
  "C_Cpp_Runner.msvcBatchPath": "C:/Program Files/Microsoft Visual Studio/2022/Community/VC/Auxiliary/Build/vcvarsall.bat",
  "C_Cpp_Runner.useMsvc": true,
  "C_Cpp_Runner.warnings": [
    "/W4",
    "/permissive-",
    "/w14242",
    "/w14287",
    "/w14296",
    "/w14311",
    "/w14826",
    "/w44062",
    "/w44242",
    "/w14905",
    "/w14906",
    "/w14263",
    "/w44265",
    "/w14928"
  ],
  "C_Cpp_Runner.enableWarnings": true,
  "C_Cpp_Runner.warningsAsError": false,
  "C_Cpp_Runner.compilerArgs": [],
  "C_Cpp_Runner.linkerArgs": [],
  "C_Cpp_Runner.includePaths": [
    "${workspaceFolder}/Source",
    "${workspaceFolder}/Source/SDK",
    "${workspaceFolder}/Source/SDK/ThirdParty",
    "${workspaceFolder}/YRpp"
  ],
  "C_Cpp_Runner.includeSearch": [
    "*",
    "**/*"
  ],
  "C_Cpp_Runner.excludeSearch": [
    "**/build",
    "**/build/**",
    "**/.*",
    "**/.*/**",
    "**/.vscode",
    "**/_vendor",
    "**/code-structure-generator/**"
  ],
  "files.associations": {
    "*.h": "cpp"
  }
}
